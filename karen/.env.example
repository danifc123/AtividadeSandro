# Variáveis de Ambiente — Karen Agent
# Copie este arquivo para .env e preencha com seus valores reais

# === Telegram ===
TELEGRAM_BOT_TOKEN="SUBSTITUA_PELO_SEU_BOT_TOKEN"

# IDs separados por vírgula (ex: 123456789,987654321)
TELEGRAM_ALLOWED_USER_IDS="SUBSTITUA_PELO_SEU_USER_ID"

# === LLM Principal — Groq ===
GROQ_API_KEY="SUBSTITUA_PELA_SUA_GROQ_API_KEY"
GROQ_MODEL="llama-3.3-70b-versatile"

# === LLM Fallback — OpenRouter ===
OPENROUTER_API_KEY="SUBSTITUA_PELA_SUA_OPENROUTER_API_KEY"
OPENROUTER_MODEL="meta-llama/llama-3.3-70b-instruct:free"

# === Memória ===
DB_PATH="./memory.db"

# === Google (para futuras integrações) ===
GOOGLE_APPLICATION_CREDENTIALS="./service-account.json"

# === Agent ===
# Número máximo de iterações do agent loop por mensagem
AGENT_MAX_ITERATIONS="10"
